---
import Layout from "../layouts/Layout.astro";
import { Navbar } from "../components/landing/Navbar";
import Footer from "../components/landing/Footer.astro";

const title = "Privacy Policy | OpenOrbit";
const description =
    "OpenOrbit's privacy policy and commitment to data transparency.";
---

<Layout title={title} description={description}>
    <div
        class="relative min-h-screen bg-[#070A12] text-[#F4F6FF] flex flex-col"
    >
        <Navbar client:load />

        <main class="flex-grow pt-32 pb-20 relative">
            {/* Background Decorative Elements */}
            <div
                class="absolute inset-0 overflow-hidden pointer-events-none"
                aria-hidden="true"
            >
                <div
                    class="absolute top-0 left-1/4 w-[500px] h-[500px] bg-[#4F6DFF]/5 rounded-full blur-[120px]"
                >
                </div>
                <div
                    class="absolute bottom-0 right-1/4 w-[500px] h-[500px] bg-[#4F6DFF]/5 rounded-full blur-[120px]"
                >
                </div>
                <div class="absolute inset-0 grid-pattern opacity-5"></div>
            </div>

            <div class="container mx-auto px-6 relative z-10">
                <div class="max-w-4xl mx-auto">
                    {/* Header */}
                    <header class="mb-14 reveal-on-scroll" data-delay="0.1">
                        <h1
                            class="text-4xl md:text-5xl font-bold tracking-tight font-[family-name:var(--font-space-grotesk)] mb-4"
                        >
                            Privacy <span class="gradient-text">Policy</span>
                        </h1>
                        <p
                            class="text-[#A7B0C8] font-[family-name:var(--font-dm-sans)] text-base"
                        >
                            Effective Date: <span class="text-white font-medium"
                                >March 22, 2026</span
                            >
                        </p>
                    </header>

                    {/* Content */}
                    <div
                        class="space-y-10 font-[family-name:var(--font-dm-sans)] text-[#A7B0C8] leading-relaxed reveal-on-scroll"
                        data-delay="0.2"
                    >
                        <section>
                            <p class="text-white/90 text-[1.05rem] mt-8">
                                At OpenOrbit ("we", "our", or "us"), accessible
                                at <a
                                    href="https://openorbit.tech"
                                    class="text-[#4F6DFF] hover:text-white transition-colors underline underline-offset-4 decoration-[#4F6DFF]/50 hover:decoration-[#4F6DFF]"
                                    >https://openorbit.tech</a
                                >, we respect your privacy and are committed to
                                transparency about how data is handled.
                            </p>
                        </section>

                        <section class="space-y-4">
                            <h2
                                class="text-2xl font-semibold text-white font-[family-name:var(--font-space-grotesk)] border-b border-white/5 pb-2 mt-4"
                            >
                                1. Information We Collect
                            </h2>
                            <p>
                                We do not directly collect personal information
                                such as names, emails, or contact details
                                through forms or account systems.
                            </p>
                            <div
                                class="mt-4 p-6 rounded-xl bg-white/[0.02] border border-white/5 mx-auto max-w-full"
                            >
                                <p class="mb-4 text-white/80">
                                    However, we use analytics tools that may
                                    automatically collect certain information,
                                    including:
                                </p>
                                <ul
                                    class="grid grid-cols-1 md:grid-cols-2 gap-3 list-none p-0"
                                >
                                    <li class="flex items-center gap-3">
                                        <div
                                            class="w-1.5 h-1.5 rounded-full bg-[#4F6DFF]"
                                        >
                                        </div>
                                        <span>IP address (anonymized)</span>
                                    </li>
                                    <li class="flex items-center gap-3">
                                        <div
                                            class="w-1.5 h-1.5 rounded-full bg-[#4F6DFF]"
                                        >
                                        </div>
                                        <span>Browser type & version</span>
                                    </li>
                                    <li class="flex items-center gap-3">
                                        <div
                                            class="w-1.5 h-1.5 rounded-full bg-[#4F6DFF]"
                                        >
                                        </div>
                                        <span>Device information</span>
                                    </li>
                                    <li class="flex items-center gap-3">
                                        <div
                                            class="w-1.5 h-1.5 rounded-full bg-[#4F6DFF]"
                                        >
                                        </div>
                                        <span>Pages visited & time spent</span>
                                    </li>
                                </ul>
                            </div>
                        </section>

                        <section class="space-y-4">
                            <h2
                                class="mt-6 text-2xl font-semibold text-white font-[family-name:var(--font-space-grotesk)] border-b border-white/5 pb-2"
                            >
                                2. Analytics
                            </h2>
                            <p>
                                We use Google Analytics to understand how
                                visitors interact with our website and to
                                improve our services. Google Analytics may use
                                cookies and similar technologies to collect and
                                analyze usage data. This information is
                                typically aggregated and does not directly
                                identify individual users.
                            </p>
                            <p>
                                You can learn more about how Google uses data at
                                the <a
                                    href="https://policies.google.com/privacy"
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="text-[#4F6DFF] hover:text-white underline underline-offset-2 transition-colors"
                                    >Google Privacy & Terms page</a
                                >.
                            </p>
                        </section>

                        <section class="mt-6 space-y-4">
                            <h2
                                class="text-2xl font-semibold text-white font-[family-name:var(--font-space-grotesk)] border-b border-white/5 pb-2"
                            >
                                3. Cookies
                            </h2>
                            <p>
                                Our website may use cookies through Google
                                Analytics to analyze traffic and usage patterns
                                and improve website performance. You can control
                                or disable cookies through your browser
                                settings.
                            </p>
                        </section>

                        <section class="mt-6 space-y-4">
                            <h2
                                class="text-2xl font-semibold text-white font-[family-name:var(--font-space-grotesk)] border-b border-white/5 pb-2"
                            >
                                4. Data Sharing
                            </h2>
                            <p>
                                We do not sell or trade your personal data. Data
                                collected via Google Analytics may be processed
                                by Google in accordance with their privacy
                                policies.
                            </p>
                        </section>

                        <section class="mt-6 space-y-4">
                            <h2
                                class="text-2xl font-semibold text-white font-[family-name:var(--font-space-grotesk)] border-b border-white/5 pb-2"
                            >
                                5. Data Security
                            </h2>
                            <p>
                                We take reasonable measures to protect our
                                website and any collected data from unauthorized
                                access.
                            </p>
                        </section>

                        <section class="mt-6 space-y-4">
                            <h2
                                class="text-2xl font-semibold text-white font-[family-name:var(--font-space-grotesk)] border-b border-white/5 pb-2"
                            >
                                6. Your Rights
                            </h2>
                            <p>
                                Depending on your location, you may have rights
                                regarding your data, including access to your
                                data, requesting deletion, or
                                restricting/objecting to processing.
                            </p>
                        </section>

                        <section class="mt-6 space-y-4">
                            <h2
                                class="text-2xl font-semibold text-white font-[family-name:var(--font-space-grotesk)] border-b border-white/5 pb-2"
                            >
                                7. Changes to This Policy
                            </h2>
                            <p>
                                We may update this Privacy Policy from time to
                                time. Changes will be posted on this page with
                                an updated effective date.
                            </p>
                        </section>

                        <section class="mt-6 space-y-4">
                            <h2
                                class="text-2xl font-semibold text-white font-[family-name:var(--font-space-grotesk)] border-b border-white/5 pb-2"
                            >
                                8. Contact Us
                            </h2>
                            <p>
                                If you have any questions about this Privacy
                                Policy, you can contact us via email at <a
                                    href="mailto:contact@openorbit.tech"
                                    class="text-[#4F6DFF] hover:text-white transition-colors underline underline-offset-4 decoration-[#4F6DFF]/50 hover:decoration-[#4F6DFF]"
                                    >contact@openorbit.tech</a
                                > or visit our website at <a
                                    href="https://openorbit.tech"
                                    class="text-[#4F6DFF] hover:text-white transition-colors underline underline-offset-4 decoration-[#4F6DFF]/50 hover:decoration-[#4F6DFF]"
                                    >https://openorbit.tech</a
                                >.
                            </p>
                        </section>
                    </div>
                </div>
            </div>
        </main>

        <Footer />
    </div>
</Layout>

<script>
    const observerOptions = {
        threshold: 0.1,
        rootMargin: "0px 0px -50px 0px",
    };

    const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
            if (entry.isIntersecting) {
                const el = entry.target as HTMLElement;
                const delay = el.getAttribute("data-delay") || "0";

                setTimeout(
                    () => {
                        el.classList.add("is-visible");
                    },
                    parseFloat(delay) * 1000,
                );

                observer.unobserve(el);
            }
        });
    }, observerOptions);

    document.querySelectorAll(".reveal-on-scroll").forEach((el) => {
        observer.observe(el);
    });
</script>

<style>
    .reveal-on-scroll {
        opacity: 0;
        transform: translateY(30px);
        will-change: transform, opacity;
    }

    .reveal-on-scroll.is-visible {
        opacity: 1;
        transform: translateY(0);
        transition: all 0.8s cubic-bezier(0.21, 0.47, 0.32, 0.98);
    }
</style>
